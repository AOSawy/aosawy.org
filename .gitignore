# ========================================
# aosawy.org — Git Ignore
# Precisely includes ONLY what the live site serves
# ========================================

# ----- JSX source files (build inputs, not served) -----
*.jsx

# ----- Build tools, pipeline, temp -----
tools/
content/
design/
src/
showcase-build/
node_modules/
.superpowers/
fix-oversized.py
*.bak
package.json
package-lock.json

# ----- Original oversized files (keep compressed versions) -----
public/research-hero-original.mp4

# ----- OS / editor -----
.DS_Store
Thumbs.db
desktop.ini
*.log

# ----- Raw 3D models (374MB STL + unoptimized GLB) -----
public/models/*
!public/models/optimized/

# ----- Empty directories -----
public/images/

# =============================================
# RAW SOURCE MATERIALS (39GB)
# Showcase HTML files have content baked in via base64.
# Only specific PDFs referenced externally are kept.
# =============================================

# --- AUC: Ignore EVERYTHING, then whitelist exact files ---
public/assets/AUC/*

# design-ii-showcase → 1 PDF
!public/assets/AUC/design-ii-project/
public/assets/AUC/design-ii-project/*
!public/assets/AUC/design-ii-project/documents/
public/assets/AUC/design-ii-project/documents/*
!public/assets/AUC/design-ii-project/documents/project-report.pdf

# fem-showcase → PDF too large (41 MiB) for Cloudflare Pages 25 MiB limit
# TODO: host on Cloudflare R2 and update link in fem-showcase.html

# failure-analysis-showcase → notes PDFs + project report
!public/assets/AUC/failure-analysis-project/
public/assets/AUC/failure-analysis-project/*
!public/assets/AUC/failure-analysis-project/documents/
public/assets/AUC/failure-analysis-project/documents/*
!public/assets/AUC/failure-analysis-project/documents/project-report.pdf
!public/assets/AUC/failure-analysis-project/notes/
public/assets/AUC/failure-analysis-project/notes/*
!public/assets/AUC/failure-analysis-project/notes/*.pdf

# --- RU: Ignore EVERYTHING, then whitelist exact PDFs ---
public/assets/RU/*

